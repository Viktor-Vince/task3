{
  "name": "mobile-tests",
  "version": "1.0.0",
  "scripts": {
    "test": "wdio run wdio.conf.ts",
    "test:emulator": "cross-env DEVICE=emulator APPIUM_PORT=4723 wdio run wdio.conf.ts",
    "test:lenovo": "cross-env DEVICE=lenovo_m10 APPIUM_PORT=4724 wdio run wdio.conf.ts",
    "test:all": "cross-env DEVICE=all wdio run wdio.conf.ts",
    "test:parallel": "run-p --continue-on-error test:emulator test:lenovo",
    "test:report": "npx allure generate allure-results --clean -o allure-report && npx allure open allure-report"
  },
  "devDependencies": {
    "@wdio/allure-reporter": "^9.0.0",
    "@wdio/appium-service": "^9.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "allure-commandline": "^2.42.1",
    "appium": "^2.11.0",
    "appium-uiautomator2-driver": "^3.0.0",
    "cross-env": "^10.1.0",
    "npm-run-all2": "^9.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
